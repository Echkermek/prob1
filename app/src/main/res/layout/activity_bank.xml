<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    tools:context=".BankActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textViewBankTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bank “Learn Remote”"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/imageViewBankLogo"
            android:layout_width="261dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:src="@drawable/bank"/>

        <TextView
            android:id="@+id/textViewBankStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Баланс"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/textViewCreditStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сумма кредита"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonTakeLoan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            android:text="Взять кредит (75 coins)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="18dp"
            app:backgroundTint="#3F779E"
            app:elevation="6dp"
            app:rippleColor="#601468D7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonExitBank"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="40dp"
            android:text="Выход"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            app:cornerRadius="18dp"
            app:backgroundTint="#3F779E"
            app:elevation="6dp"
            app:rippleColor="#601468D7" />
    </LinearLayout>
</LinearLayout>