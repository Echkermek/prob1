<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true"
    tools:context=".ui.teacher.TeacherMain">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/teacherImage"
            android:layout_width="166dp"
            android:layout_height="160dp"
            android:adjustViewBounds="true"
            android:contentDescription="Изображение преподавателя"
            android:scaleType="fitCenter"
            android:src="@drawable/teacher" />

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/groupsButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="28dp"
            android:text="Управление группами"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#207897"
            app:cornerRadius="16dp" />



        <com.google.android.material.button.MaterialButton
            android:id="@+id/calendarButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Календарь"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#207897"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/notificationsButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Сообщения"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#207897"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deadlinesButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Сроки сдачи"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#207897"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manualAnswersButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Просмотр ответов"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#207897"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btGrades"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Просмотр оценок"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="#207897"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>