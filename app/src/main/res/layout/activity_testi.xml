<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Добавление вопроса"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center"/>

    <!-- Spinner для выбора теста -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выберите тест:"/>

    <Spinner
        android:id="@+id/spinnerTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- Spinner для выбора части теста -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выберите часть теста:"/>

    <Spinner
        android:id="@+id/spinnerPart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- Поле для номера вопроса -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Номер вопроса:"/>

    <EditText
        android:id="@+id/etQuestionNum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:layout_marginBottom="16dp"/>

    <!-- Поле для вопроса -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Вопрос:"/>

    <EditText
        android:id="@+id/etQuestion"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginBottom="16dp"/>

    <!-- Поле для контента (устный ответ) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Контент (для устного ответа, или '-' если не нужно):"/>

    <EditText
        android:id="@+id/etContent"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginBottom="16dp"/>

    <!-- Кнопка добавления -->
    <Button
        android:id="@+id/btnAddQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Добавить вопрос"
        android:layout_marginBottom="16dp"/>

    <!-- Кнопка просмотра вопросов -->
    <Button
        android:id="@+id/btnViewQuestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Просмотр вопросов"/>

</LinearLayout>